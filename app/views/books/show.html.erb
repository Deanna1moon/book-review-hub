<style>
  @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }
  @keyframes drift { 0%, 100% { transform: translateX(0px) rotate(0deg); } 50% { transform: translateX(20px) rotate(15deg); } }
  @keyframes drift-reverse { 0%, 100% { transform: translateX(0px) rotate(0deg); } 50% { transform: translateX(-20px) rotate(-15deg); } }
  @keyframes float-slow { 0%, 100% { transform: translateY(0px) rotate(0deg); } 50% { transform: translateY(-15px) rotate(10deg); } }
  .animate-float { animation: float 6s ease-in-out infinite; }
  .animate-drift { animation: drift 15s ease-in-out infinite; }
  .animate-drift-rev { animation: drift-reverse 18s ease-in-out infinite; }
  .animate-float-slow { animation: float-slow 8s ease-in-out infinite; }
  
  .leaf { position: fixed; opacity: 0.25; pointer-events: none; font-size: 2.5rem; }
  .leaf-drift { animation: drift 20s ease-in-out infinite; }
  .leaf-drift-rev { animation: drift-reverse 25s ease-in-out infinite; }
  .leaf-float { animation: float-slow 12s ease-in-out infinite; }
  
  .ice-shape { position: absolute; opacity: 0.12; }
  .ice-1 { width: 150px; height: 150px; background: conic-gradient(from 0deg, rgba(34,211,238,0.3), rgba(99,102,241,0.2), rgba(34,211,238,0.3)); clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%); animation: float 20s ease-in-out infinite; }
  .ice-2 { width: 120px; height: 120px; background: conic-gradient(from 45deg, rgba(99,102,241,0.25), rgba(34,211,238,0.25)); clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%); animation: float-slow 15s ease-in-out infinite reverse; }
  .ice-3 { width: 180px; height: 180px; background: radial-gradient(circle, rgba(34,211,238,0.2), transparent); clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); animation: drift 30s linear infinite; }
</style>

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-slate-900 to-indigo-950 relative overflow-hidden">
  <!-- Animated Leaves -->
  <div class="leaf leaf-drift" style="top: 10%; left: 5%;">🍂</div>
  <div class="leaf leaf-drift-rev" style="top: 20%; right: 8%;">🍃</div>
  <div class="leaf leaf-float" style="top: 35%; left: 12%;">🌿</div>
  <div class="leaf leaf-drift" style="top: 50%; right: 10%;">🍂</div>
  <div class="leaf leaf-drift-rev" style="bottom: 30%; left: 8%;">🍃</div>
  <div class="leaf leaf-float" style="bottom: 15%; right: 12%;">🌿</div>
  
  <!-- Ice Shapes -->
  <div class="ice-shape ice-1" style="top: 15%; right: 10%;"></div>
  <div class="ice-shape ice-2" style="top: 50%; left: 5%;"></div>
  <div class="ice-shape ice-3" style="bottom: 25%; right: 8%;"></div>
  
  <!-- Decorative Magical Aura -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-gradient-radial from-indigo-500/10 to-transparent blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-gradient-radial from-cyan-500/10 to-transparent blur-3xl"></div>
  
  <div class="max-w-5xl mx-auto px-4 py-12 relative z-10">
    
    <%= link_to "← Back to Books",
        books_path,
        class: "inline-flex items-center text-indigo-300 hover:text-cyan-300 font-medium mb-10 transition" %>

    <!-- Book Detail Section -->
    <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl shadow-2xl p-8 md:p-12 border border-indigo-500/30 mb-10 relative">
      <!-- Magical shimmer border -->
      <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-cyan-500/10 via-indigo-500/5 to-cyan-500/10 opacity-0 hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
      
      <!-- Top accent line with animation -->
      <div class="h-1 bg-gradient-to-r from-indigo-600 via-cyan-500 to-indigo-600 rounded-full mb-8 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-cyan-300 to-transparent opacity-50 animate-pulse"></div>
      </div>

      <!-- Book Details Layout -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Left: Cover Image with Magical Frame -->
        <% if @book.cover_image.attached? %>
          <div class="md:col-span-1">
            <!-- Magical glow -->
            <div class="absolute -inset-4 bg-gradient-to-r from-cyan-500/20 to-indigo-500/20 rounded-2xl blur-xl"></div>
            <div class="relative rounded-xl overflow-hidden shadow-2xl border border-indigo-500/50 hover:border-cyan-400/70 transition-colors">
              <%= image_tag @book.cover_image,
                  class: "w-full h-96 object-cover" %>
              <!-- Ethereal overlay -->
              <div class="absolute inset-0 bg-gradient-to-b from-cyan-500/10 via-transparent to-indigo-900/20"></div>
            </div>
          </div>
        <% end %>

        <!-- Right: Details -->
        <div class="<%= @book.cover_image.attached? ? 'md:col-span-2' : '' %> space-y-6">
          <div>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-3">
              <%= @book.title %>
            </h1>
            <p class="text-lg text-indigo-300 font-medium">
              by <%= @book.author %>
            </p>
          </div>

          <!-- Genre Badge -->
          <div>
            <span class="inline-block bg-gradient-to-r from-indigo-600 to-cyan-600 text-white px-5 py-1.5 rounded-full font-semibold uppercase text-xs tracking-wide">
              <%= @book.genre %>
            </span>
          </div>

          <!-- Description -->
          <div class="border-l-4 border-cyan-500/40 pl-6 py-2">
            <h3 class="text-indigo-200 font-semibold text-sm uppercase tracking-wide mb-3">Summary</h3>
            <p class="text-slate-300 leading-relaxed text-base">
              <%= @book.description %>
            </p>
          </div>

          <!-- Owner Actions -->
          <% if current_user && @book.user_id == current_user.id %>
            <div class="flex flex-col sm:flex-row gap-3 pt-4">
              <%= link_to "Edit Book",
                  edit_book_path(@book),
                  class: "flex-1 text-center px-5 py-2.5 bg-amber-600 hover:bg-amber-700 text-white font-semibold rounded-lg transition-colors duration-200" %>

              <%= button_to "Remove Book",
                  @book,
                  method: :delete,
                  data: { turbo_confirm: "This cannot be undone. Are you certain?" },
                  class: "flex-1 px-5 py-2.5 bg-red-700 hover:bg-red-800 text-white font-semibold rounded-lg transition-colors duration-200" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Reviews Section -->
    <div class="space-y-8">
      <!-- Add Review Form -->
      <% if current_user %>
        <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl shadow-xl p-8 border border-indigo-500/20">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-8 bg-gradient-to-b from-cyan-500 to-indigo-600 rounded-full"></div>
            <h2 class="text-2xl font-bold text-white">
              Add Review
            </h2>
          </div>

          <%= form_with model: [@book, Review.new], local: true, class: "space-y-6" do |form| %>
            <!-- Rating Input -->
            <div>
              <label class="block text-indigo-200 font-semibold mb-4">Rate This Book</label>
              <div class="flex space-x-2" id="review-star-rating">
                <% (1..5).each do |i| %>
                  <input type="radio" name="review[rating]" value="<%= i %>" id="review_rating_<%= i %>" class="hidden" />
                  <label for="review_rating_<%= i %>" class="cursor-pointer text-4xl transition-all hover:scale-110" data-star-value="<%= i %>">
                    <span class="text-slate-600">★</span>
                  </label>
                <% end %>
              </div>
              <script>
                (function() {
                  const ratingContainer = document.getElementById('review-star-rating');
                  if (!ratingContainer) return;
                  
                  const labels = ratingContainer.querySelectorAll('label');
                  const starSpans = ratingContainer.querySelectorAll('span');
                  let selectedRating = 0;

                  function updateStarDisplay(rating) {
                    starSpans.forEach((span, idx) => {
                      if (idx < rating) {
                        span.textContent = '★';
                        span.className = 'text-amber-400';
                      } else {
                        span.textContent = '★';
                        span.className = 'text-slate-600';
                      }
                    });
                  }

                  labels.forEach((label) => {
                    label.addEventListener('mouseenter', () => {
                      const hoverRating = parseInt(label.dataset.starValue);
                      updateStarDisplay(hoverRating);
                    });

                    label.addEventListener('click', (e) => {
                      e.preventDefault();
                      const rating = parseInt(label.dataset.starValue);
                      selectedRating = rating;
                      document.getElementById(`review_rating_${rating}`).checked = true;
                      updateStarDisplay(rating);
                    });
                  });

                  ratingContainer.addEventListener('mouseleave', () => {
                    updateStarDisplay(selectedRating);
                  });

                  const checkedInput = ratingContainer.querySelector('input:checked');
                  if (checkedInput) {
                    selectedRating = parseInt(checkedInput.value);
                    updateStarDisplay(selectedRating);
                  }
                })();
              </script>
            </div>

            <!-- Comment Textarea -->
            <div>
              <label class="block text-indigo-200 font-semibold mb-3">Your Thoughts</label>
              <%= form.text_area :comment,
                  rows: 5,
                  placeholder: "Share your impressions of this b...",
                  class: "w-full px-4 py-3 bg-slate-700 text-white placeholder-slate-500 border border-indigo-500/30 rounded-lg focus:outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20" %>
            </div>

            <!-- Submit Button -->
            <%= form.submit "Add Review",
                class: "w-full px-6 py-3 bg-gradient-to-r from-indigo-600 to-cyan-600 hover:from-indigo-500 hover:to-cyan-500 text-white font-semibold rounded-lg transition-all duration-200" %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-indigo-500/10 border border-indigo-500/30 rounded-xl p-8 text-center">
          <p class="text-indigo-200 mb-4 font-medium">Sign in to share your thoughts</p>
          <%= link_to "Login",
              login_path,
              class: "inline-block px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-colors" %>
        </div>
      <% end %>

      <!-- Reviews List -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-8 bg-gradient-to-b from-cyan-500 to-indigo-600 rounded-full"></div>
          <h2 class="text-2xl font-bold text-white">Reviews (<%= @book.reviews.count %>)</h2>
        </div>

        <% if @book.reviews.any? %>
          <div class="space-y-4">
            <% @book.reviews.each do |review| %>
              <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-xl shadow-lg p-6 border border-indigo-500/20 hover:border-cyan-500/30 transition-colors">
                <!-- Reviewer info -->
                <div class="flex justify-between items-start mb-4">
                  <p class="text-indigo-300 font-semibold text-base">
                    <%= review.user ? review.user.email.split('@')[0] : "Anonymous" %>
                  </p>
                  
                  <!-- Star rating display -->
                  <div class="flex space-x-0.5 items-center gap-2">
                    <% review.rating.times do %>
                      <span class="text-amber-400 text-lg">★</span>
                    <% end %>
                    <% (5 - review.rating).times do %>
                      <span class="text-slate-600 text-lg">★</span>
                    <% end %>
                    <span class="text-slate-400 ml-1 font-semibold"><%= review.rating %>/5</span>
                  </div>
                </div>

                <!-- Review comment -->
                <p class="text-slate-300 leading-relaxed">
                  <%= review.comment %>
                </p>

                <!-- Delete button for owner -->
                <% if current_user && review.user_id == current_user.id %>
                  <div class="mt-4">
                    <%= button_to "Delete",
                      book_review_path(@book, review),
                      method: :delete,
                      data: { turbo_confirm: "Delete this review?" },
                      class: "text-red-400 hover:text-red-300 font-semibold text-sm transition" %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12 bg-slate-800/50 rounded-xl border border-indigo-500/20">
            <p class="text-slate-400 text-base">No reviews yet. Be the first to share your thoughts.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

