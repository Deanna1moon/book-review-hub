<div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900">
  <div class="max-w-4xl mx-auto px-4 py-12">
    
    <!-- REDESIGN: Back button -->
    <%= link_to "← Back to Books",
        books_path,
        class: "inline-flex items-center text-purple-400 hover:text-purple-300 font-semibold mb-8 transition" %>

    <!-- REDESIGN: Book Header Section -->
    <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-8 md:p-12 border border-purple-500/20 mb-12">
      <!-- Gradient accent -->
      <div class="h-1 bg-gradient-to-r from-purple-600 via-pink-500 to-purple-600 rounded-full mb-8"></div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- REDESIGN: Book Cover simulation -->
        <div class="hidden md:block">
          <div class="bg-gradient-to-br from-purple-600 to-pink-600 rounded-xl p-8 shadow-glow-lg min-h-80 flex flex-col justify-end">
            <div class="text-6xl text-center mb-4">📖</div>
            <h2 class="text-white font-bold text-center text-lg line-clamp-3"><%= @book.title %></h2>
          </div>
        </div>

        <!-- Book Details -->
        <div class="md:col-span-2 space-y-6">
          <div>
            <h1 class="text-4xl md:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-300 to-pink-300 mb-2">
              <%= @book.title %>
            </h1>
            <p class="text-purple-300 text-xl font-semibold flex items-center space-x-2">
              <span>✍️</span>
              <span><%= @book.author %></span>
            </p>
          </div>

          <!-- Genre Badge -->
          <div>
            <span class="inline-block bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-2 rounded-full font-bold uppercase text-sm">
              <%= @book.genre %>
            </span>
          </div>

          <!-- Description -->
          <div class="border-l-4 border-purple-500 pl-6">
            <h3 class="text-gray-300 font-semibold text-sm uppercase mb-2">📖 Description</h3>
            <p class="text-gray-200 leading-relaxed text-lg">
              <%= @book.description %>
            </p>
          </div>

          <!-- Review Stats -->
          <div class="bg-purple-900/30 rounded-lg p-4 border border-purple-500/20">
            <div class="flex items-center space-x-2 text-purple-300">
              <span class="text-2xl">⭐</span>
              <span class="font-bold"><%= @book.reviews.count %> Review<%= 's' if @book.reviews.count != 1 %></span>
            </div>
          </div>

          <!-- REDESIGN: Owner Actions -->
          <% if current_user && @book.user_id == current_user.id %>
            <div class="flex flex-col sm:flex-row gap-3 pt-4">
              <%= link_to "✏️ Edit Book",
                  edit_book_path(@book),
                  class: "flex-1 text-center px-6 py-3 bg-yellow-600 hover:bg-yellow-700 text-white font-bold rounded-lg transition" %>

              <%= button_to "🗑️ Delete Book",
                  @book,
                  method: :delete,
                  data: { turbo_confirm: "Are you sure? This cannot be undone." },
                  class: "flex-1 px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg transition" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- REDESIGN: Reviews Section -->
    <div class="space-y-8">
      <!-- Add Review Form -->
      <% if current_user %>
        <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-xl p-8 border border-purple-500/20">
          <h2 class="text-2xl font-bold text-white mb-6">
            ✨ Share Your Review
          </h2>

          <%= form_with model: [@book, Review.new], local: true, class: "space-y-6" do |form| %>
            <!-- Rating Input -->
            <div>
              <label class="block text-purple-300 font-semibold mb-3">Rating (1-5 stars)</label>
              <div class="flex space-x-1" id="review-star-rating">
                <% (1..5).each do |i| %>
                  <input type="radio" name="review[rating]" value="<%= i %>" id="review_rating_<%= i %>" class="hidden" />
                  <label for="review_rating_<%= i %>" class="cursor-pointer text-5xl transition-transform hover:scale-125" data-star-value="<%= i %>">
                    <span class="text-gray-400">★</span>
                  </label>
                <% end %>
              </div>
              <script>
                // REDESIGN: Fixed interactive star rating
                (function() {
                  const ratingContainer = document.getElementById('review-star-rating');
                  if (!ratingContainer) return;
                  
                  const labels = ratingContainer.querySelectorAll('label');
                  const starSpans = ratingContainer.querySelectorAll('span');
                  let selectedRating = 0;

                  function updateStarDisplay(rating) {
                    starSpans.forEach((span, idx) => {
                      if (idx < rating) {
                        span.textContent = '★';
                        span.className = 'text-yellow-400';
                      } else {
                        span.textContent = '★';
                        span.className = 'text-gray-400';
                      }
                    });
                  }

                  labels.forEach((label) => {
                    label.addEventListener('mouseenter', () => {
                      const hoverRating = parseInt(label.dataset.starValue);
                      updateStarDisplay(hoverRating);
                    });

                    label.addEventListener('click', (e) => {
                      e.preventDefault();
                      const rating = parseInt(label.dataset.starValue);
                      selectedRating = rating;
                      document.getElementById(`review_rating_${rating}`).checked = true;
                      updateStarDisplay(rating);
                    });
                  });

                  ratingContainer.addEventListener('mouseleave', () => {
                    updateStarDisplay(selectedRating);
                  });

                  // Initialize display
                  const checkedInput = ratingContainer.querySelector('input:checked');
                  if (checkedInput) {
                    selectedRating = parseInt(checkedInput.value);
                    updateStarDisplay(selectedRating);
                  }
                })();
              </script>
            </div>

            <!-- Comment Textarea -->
            <div>
              <label class="block text-purple-300 font-semibold mb-3">Your Thoughts</label>
              <%= form.text_area :comment,
                  rows: 5,
                  placeholder: "What did you think about this book? Share your insights...",
                  class: "w-full px-4 py-3 bg-gray-700 text-white placeholder-gray-500 border border-purple-500/30 rounded-lg focus:outline-none focus:border-purple-400 focus:ring-2 focus:ring-purple-400/30" %>
            </div>

            <!-- Submit Button -->
            <%= form.submit "Post Review →",
                class: "w-full px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold rounded-lg transition" %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-purple-900/20 border border-purple-500/30 rounded-xl p-8 text-center">
          <p class="text-gray-300 mb-4">Log in to share your review</p>
          <%= link_to "Login",
              login_path,
              class: "inline-block px-6 py-2 bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-lg transition" %>
        </div>
      <% end %>

      <!-- Reviews List -->
      <div>
        <h2 class="text-3xl font-bold text-white mb-6 flex items-center space-x-2">
          <span>💬</span>
          <span>Reviews (<%= @book.reviews.count %>)</span>
        </h2>

        <% if @book.reviews.any? %>
          <div class="space-y-4">
            <% @book.reviews.each do |review| %>
              <!-- REDESIGN: Review card -->
              <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-xl shadow-lg p-6 border border-purple-500/20 hover:border-purple-400/40 transition">
                <!-- Reviewer info -->
                <div class="flex justify-between items-start mb-4">
                  <div>
                    <p class="text-purple-300 font-semibold flex items-center space-x-2">
                      <span>👤</span>
                      <span><%= review.user&.email || "Anonymous" %></span>
                    </p>
                  </div>
                  
                  <!-- Star rating display -->
                  <div class="flex space-x-1">
                    <% review.rating.times do %>
                      <span class="text-yellow-400 text-lg">★</span>
                    <% end %>
                    <% (5 - review.rating).times do %>
                      <span class="text-gray-600 text-lg">★</span>
                    <% end %>
                    <span class="text-gray-400 ml-2 font-bold"><%= review.rating %>/5</span>
                  </div>
                </div>

                <!-- Review comment -->
                <p class="text-gray-200 leading-relaxed mb-4 text-lg">
                  <%= review.comment %>
                </p>

                <!-- Delete button for owner -->
                <% if current_user && review.user_id == current_user.id %>
                  <%= button_to "🗑️ Delete",
                    book_review_path(@book, review),
                    method: :delete,
                    data: { turbo_confirm: "Delete this review?" },
                    class: "text-red-400 hover:text-red-300 font-semibold text-sm transition" %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12 bg-gray-900/50 rounded-xl border border-purple-500/20">
            <p class="text-gray-400 text-lg">No reviews yet. Be the first to share your thoughts!</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

