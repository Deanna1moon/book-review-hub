<div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900">
  <!-- REDESIGN: Hero Section -->
  <div class="max-w-7xl mx-auto px-4 py-16 sm:py-24">
    <div class="text-center mb-16">
      <h1 class="text-5xl md:text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-300 via-purple-200 to-pink-300 mb-4">
        📚 Discover Amazing Books
      </h1>
      <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
        Explore our collection of books, share your reviews, and connect with other readers
      </p>
      
      <!-- REDESIGN: Add Book Button with gradient -->
      <%= link_to "➕ Add Your Book",
          new_book_path,
          class: "inline-block px-8 py-4 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold rounded-xl shadow-lg hover:shadow-glow-lg transition transform hover:scale-105" %>
    </div>

    <% if @books.any? %>
      <!-- REDESIGN: Grid layout with book cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @books.each do |book| %>
          <!-- REDESIGN: Book card resembles book cover with elevated design -->
          <div class="group relative">
            <!-- Book card with hover effect -->
            <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-xl overflow-hidden shadow-xl hover:shadow-glow-lg transition-all duration-300 transform group-hover:scale-105 border border-purple-500/20">
              
              <!-- REDESIGN: Gradient accent top -->
              <div class="h-1 bg-gradient-to-r from-purple-600 via-pink-500 to-purple-600"></div>

              <div class="p-6">
                <!-- Book Title -->
                <h2 class="text-2xl font-bold text-white mb-3 group-hover:text-purple-300 transition line-clamp-2">
                  <%= book.title %>
                </h2>

                <!-- Author with icon -->
                <p class="text-purple-300 mb-3 flex items-center space-x-2">
                  <span>✍️</span>
                  <span class="font-semibold"><%= book.author %></span>
                </p>

                <!-- Genre badge -->
                <div class="mb-4">
                  <span class="inline-block bg-gradient-to-r from-purple-600 to-pink-600 text-white text-xs px-4 py-2 rounded-full font-semibold uppercase tracking-wider">
                    <%= book.genre %>
                  </span>
                </div>

                <!-- Description -->
                <p class="text-gray-300 mb-6 line-clamp-3 leading-relaxed">
                  <%= book.description %>
                </p>

                <!-- REDESIGN: Added Reviews count -->
                <div class="text-sm text-gray-400 mb-4 flex items-center space-x-1">
                  <span>⭐</span>
                  <span><%= book.reviews.count %> review<%= 's' if book.reviews.count != 1 %></span>
                </div>

                <!-- Action button -->
                <%= link_to "View Details →",
                    book_path(book),
                    class: "inline-block w-full text-center py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold rounded-lg transition transform hover:translate-x-1" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

    <% else %>
      <!-- REDESIGN: Empty state with engaging message -->
      <div class="text-center py-24">
        <div class="text-6xl mb-4">📖</div>
        <h2 class="text-3xl font-bold text-gray-300 mb-4">No books yet</h2>
        <p class="text-gray-400 mb-8 text-lg">Be the first to add a book to our collection!</p>
        <%= link_to "Add First Book",
            new_book_path,
            class: "inline-block px-8 py-4 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold rounded-xl transition transform hover:scale-105" %>
      </div>
    <% end %>
  </div>
</div>