<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Book Review Hub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Book Review Hub">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Tailwind CSS via CDN - REDESIGN: Added for purple-themed modern frontend %>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <%# Custom Tailwind config for indigo/cyan theme %>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'gradient-dark': 'linear-gradient(135deg, #312e81 0%, #1e293b 100%)',
            },
            boxShadow: {
              'glow': '0 0 20px rgba(34, 211, 238, 0.2)',
              'glow-lg': '0 0 40px rgba(34, 211, 238, 0.3)',
            },
            backgroundImage: {
              'gradient-indigo': 'linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%)',
              'gradient-dark': 'linear-gradient(135deg, #312e81 0%, #1e293b 100%)',
            }
          }
        }
      }
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-indigo-950 text-gray-100">
    <!-- Modern navigation bar with indigo/cyan theme -->
    <nav class="bg-gradient-to-r from-indigo-950 to-slate-900 border-b border-indigo-500/30 sticky top-0 z-50 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          
          <!-- Logo/Brand -->
          <div class="flex items-center space-x-3">
            <div class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-indigo-300">
              Book Hub
            </div>
          </div>

          <!-- Navigation Links -->
          <div class="hidden md:flex items-center space-x-8">
            <%= link_to "Home", root_path, class: "text-indigo-200 hover:text-cyan-400 transition font-medium" %>
            <%= link_to "Browse", books_path, class: "text-indigo-200 hover:text-cyan-400 transition font-medium" %>
            
            <% if current_user %>
              <span class="text-indigo-400 text-sm">|</span>
              <span class="text-indigo-300 text-sm"><%= current_user.email %></span>
            <% end %>
          </div>

          <!-- Auth Buttons -->
          <div class="flex items-center space-x-3">
            <% if current_user %>
              <%= button_to "Logout",
                  logout_path,
                  method: :delete,
                  class: "px-4 py-2 bg-slate-700 hover:bg-slate-600 text-indigo-200 hover:text-cyan-200 rounded-lg font-semibold transition" %>
            <% else %>
              <%= link_to "Login", login_path, class: "px-4 py-2 text-cyan-400 hover:text-cyan-300 font-semibold transition" %>
              <%= link_to "Sign Up", new_user_path, class: "px-4 py-2 bg-gradient-to-r from-indigo-600 to-cyan-600 hover:from-indigo-500 hover:to-cyan-500 text-white rounded-lg font-semibold transition" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash messages with theme styling -->
    <% if notice %>
      <div class="bg-gradient-to-r from-cyan-600 to-indigo-600 text-white px-6 py-3 shadow-lg">
        <div class="max-w-7xl mx-auto flex items-center space-x-3">
          <span class="text-xl">✓</span>
          <p class="font-semibold"><%= notice %></p>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="bg-gradient-to-r from-red-500 to-pink-600 text-white px-6 py-3 shadow-lg">
        <div class="max-w-7xl mx-auto flex items-center space-x-3">
          <span class="text-xl">✕</span>
          <p class="font-semibold"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="min-h-screen">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-gradient-to-r from-indigo-950 to-slate-900 border-t border-indigo-500/30 mt-20 py-12">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <p class="text-lg font-semibold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-indigo-300 mb-3">Discover. Review. Connect.</p>
        <p class="text-sm text-indigo-300">© 2026 Book Hub. Share your reading love.</p>
      </div>
    </footer>
  </body>
</html>
