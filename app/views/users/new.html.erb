<!-- REDESIGN: Modern signup page with purple theme -->
<div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <!-- Logo/Branding -->
    <div class="text-center mb-12">
      <div class="text-5xl mb-4">🚀</div>
      <h1 class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-300 to-pink-300 mb-2">
        Join Our Community
      </h1>
      <p class="text-gray-400">Create your account and start reviewing books</p>
    </div>

    <!-- Signup Form -->
    <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-8 border border-purple-500/20">
      <!-- Gradient accent -->
      <div class="h-1 bg-gradient-to-r from-purple-600 via-pink-500 to-purple-600 rounded-full mb-8"></div>

      <%= form_with model: @user, local: true, class: "space-y-6" do |form| %>
        
        <!-- Error messages if any -->
        <% if @user.errors.any? %>
          <div class="bg-red-900/30 border border-red-500/50 rounded-xl p-4">
            <h3 class="text-red-300 font-bold mb-2">⚠️ Signup failed:</h3>
            <ul class="text-red-200 space-y-1 text-sm">
              <% @user.errors.full_messages.each do |message| %>
                <li>• <%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Email Field -->
        <div>
          <label class="block text-purple-300 font-semibold mb-3">Email Address</label>
          <%= form.email_field :email,
              placeholder: "Enter your email",
              class: "w-full px-4 py-3 bg-gray-700 text-white placeholder-gray-500 border border-purple-500/30 rounded-lg focus:outline-none focus:border-purple-400 focus:ring-2 focus:ring-purple-400/30 transition" %>
        </div>

        <!-- Password Field -->
        <div>
          <label class="block text-purple-300 font-semibold mb-3">Password</label>
          <%= form.password_field :password,
              placeholder: "Create a strong password",
              class: "w-full px-4 py-3 bg-gray-700 text-white placeholder-gray-500 border border-purple-500/30 rounded-lg focus:outline-none focus:border-purple-400 focus:ring-2 focus:ring-purple-400/30 transition" %>
          <p class="text-gray-400 text-sm mt-2">✓ Use a mix of letters, numbers, and symbols</p>
        </div>

        <!-- Confirm Password Field -->
        <div>
          <label class="block text-purple-300 font-semibold mb-3">Confirm Password</label>
          <%= form.password_field :password_confirmation,
              placeholder: "Re-enter your password",
              class: "w-full px-4 py-3 bg-gray-700 text-white placeholder-gray-500 border border-purple-500/30 rounded-lg focus:outline-none focus:border-purple-400 focus:ring-2 focus:ring-purple-400/30 transition" %>
        </div>

        <!-- Signup Button -->
        <%= form.submit "✨ Create Account",
            class: "w-full px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold rounded-lg transition transform hover:scale-105" %>
      <% end %>

      <!-- Divider -->
      <div class="flex items-center space-x-4 my-8">
        <div class="flex-1 border border-purple-500/30"></div>
        <span class="text-gray-400 text-sm">or</span>
        <div class="flex-1 border border-purple-500/30"></div>
      </div>

      <!-- Login Link -->
      <div class="text-center">
        <p class="text-gray-300 mb-4">Already have an account?</p>
        <%= link_to "Sign In",
            login_path,
            class: "inline-block px-6 py-3 bg-gray-700 hover:bg-gray-600 text-purple-300 hover:text-purple-200 font-bold rounded-lg transition" %>
      </div>
    </div>

    <!-- Decorative element -->
    <div class="mt-12 text-center text-gray-500">
      <p class="text-sm">Your reading journey starts here 📖</p>
    </div>
  </div>
</div>